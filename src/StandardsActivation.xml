  <standard name="CUSTOM RULES">
    <section name="1 Files">
      <check id="1.1" state="on">
        <comment># Violation when file name uses uppercase letters or contains spaces</comment>
        <convention>File names should be lowercase and without spaces</convention>
        <pattern>[a-z][a-z0-9_]*.c</pattern>
      </check>
    </section>
    <section name="2 Preprocessing">
      <check id="2.1" state="on">
        <comment># Violation when macros use lowercase letters</comment>
        <convention>Macros should be uppercased</convention>
        <pattern>[A-Z][A-Z0-9_]*</pattern>
      </check>
    </section>
    <section name="3 Typedefs">
      <check id="3.1" state="on">
        <comment># Violation when typedef statements do not end with &#34;_t&#34;</comment>
        <convention>Typedefs should finish by &#34;_t&#34;</convention>
        <pattern>[A-Za-z0-9_]*_t</pattern>
      </check>
      <check id="3.2" state="on">
        <comment># Violation when typedef statements do not end with &#34;_t&#34;</comment>
        <convention>Typedefs should finish by &#34;_t&#34;</convention>
        <pattern>[A-Za-z0-9_]*_t</pattern>
      </check>
      <check id="3.3" state="on">
        <comment># Violation when typedef statements do not end with &#34;_t&#34;</comment>
        <convention>Typedefs should finish by &#34;_t&#34;</convention>
        <pattern>[A-Za-z0-9_]*_t</pattern>
      </check>
      <check id="3.4" state="on">
        <comment># Violation when typedef statements do not end with &#34;_t&#34;</comment>
        <convention>Typedefs should finish by &#34;_t&#34;</convention>
        <pattern>[A-Za-z0-9_]*_t</pattern>
      </check>
      <check id="3.5" state="on">
        <comment># Violation when typedef statements do not end with &#34;_t&#34;</comment>
        <convention>Typedefs should finish by &#34;_t&#34;</convention>
        <pattern>[A-Za-z0-9_]*_t</pattern>
